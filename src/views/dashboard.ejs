<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div>
          <p class="eyebrow">MySQL Project</p>
          <h1>Student Management System</h1>
          <p class="subtitle">
            Manage student details, subject-wise marks, search records, and identify top performers.
          </p>
        </div>
        <form class="search-form" action="/" method="get">
          <input
            type="text"
            name="search"
            placeholder="Search by student name"
            value="<%= search %>"
          />
          <button type="submit">Search</button>
        </form>
      </section>

      <% if (message) { %>
        <div class="alert <%= message.type %>"><%= message.text %></div>
      <% } %>

      <section class="grid two-columns">
        <article class="card">
          <h2>Add Student</h2>
          <form action="/students" method="post" class="stack">
            <input type="text" name="studentName" placeholder="Student Name" required />
            <input type="text" name="fatherName" placeholder="Father Name" required />
            <input type="text" name="motherName" placeholder="Mother Name" required />
            <textarea name="address" placeholder="Address" rows="4" required></textarea>
            <button type="submit">Save Student</button>
          </form>
        </article>

        <article class="card">
          <h2>Add Marks</h2>
          <form action="/marks" method="post" class="stack">
            <select name="studentId" required>
              <option value="">Select Student</option>
              <% studentOptions.forEach((student) => { %>
                <option value="<%= student.id %>"><%= student.student_name %></option>
              <% }) %>
            </select>
            <input type="text" name="subjectName" placeholder="Subject Name" required />
            <input type="number" name="marksObtained" placeholder="Obtained Marks" min="0" step="0.01" required />
            <input type="number" name="maxMarks" placeholder="Max Marks" min="1" step="0.01" value="100" required />
            <button type="submit">Save Marks</button>
          </form>
        </article>
      </section>

      <section class="grid two-columns">
        <article class="card">
          <div class="section-heading">
            <h2>Top Students</h2>
            <span>Highest Percentage</span>
          </div>
          <div class="mini-list">
            <% if (topStudents.length === 0) { %>
              <p>No marks data available yet.</p>
            <% } else { %>
              <% topStudents.forEach((student, index) => { %>
                <div class="mini-item">
                  <strong>#<%= index + 1 %> <%= student.student_name %></strong>
                  <span><%= student.percentage %>%</span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </article>

        <article class="card">
          <div class="section-heading">
            <h2>Marks Table</h2>
            <span>Subject Wise</span>
          </div>
          <div class="table-wrap short">
            <table>
              <thead>
                <tr>
                  <th>Student</th>
                  <th>Subject</th>
                  <th>Marks</th>
                  <th>Max</th>
                </tr>
              </thead>
              <tbody>
                <% if (marks.length === 0) { %>
                  <tr>
                    <td colspan="4" class="empty-cell">No marks entered yet.</td>
                  </tr>
                <% } else { %>
                  <% marks.forEach((mark) => { %>
                    <tr>
                      <td><%= mark.student_name %></td>
                      <td><%= mark.subject_name %></td>
                      <td><%= mark.marks_obtained %></td>
                      <td><%= mark.max_marks %></td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </article>
      </section>

      <section class="card">
        <div class="section-heading">
          <h2>Students Table</h2>
          <span>All Data</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Father Name</th>
                <th>Mother Name</th>
                <th>Address</th>
                <th>Subjects</th>
                <th>Total Marks</th>
                <th>Percentage</th>
              </tr>
            </thead>
            <tbody>
              <% if (students.length === 0) { %>
                <tr>
                  <td colspan="7" class="empty-cell">No students found.</td>
                </tr>
              <% } else { %>
                <% students.forEach((student) => { %>
                  <tr>
                    <td><%= student.student_name %></td>
                    <td><%= student.father_name %></td>
                    <td><%= student.mother_name %></td>
                    <td><%= student.address %></td>
                    <td><%= student.total_subjects %></td>
                    <td><%= student.total_marks %> / <%= student.total_max_marks %></td>
                    <td><%= student.percentage %>%</td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
